<% layout("/layouts/boilerplate") -%>
<body>
  <section class="show-section">
    <div class="row mb-5">
      <div class="col-lg-8 offset-lg-2 col-md-8 offset-md-2">
        <h1 class="mt-3">Listing Details</h1>
        <div class="card">
          <img
            src="<%=listing.image%>"
            class="card-img-top show-img object-fit-cover"
            alt="..."
          />

          <!-- .toLocaleString("en-IN" -->
          <div class="card-body">
            <h5 class="card-title"><%=listing.title%></h5>
            <p class="card-text"><%=listing.description%></p>
            <p class="card-text">&#8377; <%=listing.price%></p>
            <p class="card-text"><%=listing.location%></p>
            <p class="card-text"><%=listing.country%></p>
          </div>

          <div class="card-body d-flex gap-4">
            <button class="rounded btn-primary border-0 px-3 py-1">
              <a
                href="/listings/<%=listing.id%>/edit"
                class="card-link text-decoration-none text-white"
                >Edit</a
              >
            </button>
            <form
              method="POST"
              action="/listings/<%= listing.id %>?_method=DELETE"
            >
              <button
                class="rounded btn-primary bg-black border-0 text-white px-3 py-1"
              >
                Delete
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

